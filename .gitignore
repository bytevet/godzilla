# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# Godzilla specific
bin/
# The compiled CLI binary at the repo root (anchored, so it does NOT match the
# cmd/godzilla/ source directory).
/godzilla

# IDEs
.idea/
.vscode/
.claude/

# OS
.DS_Store

# Compiled binaries a bare `go build` leaves inside a Go sample dir (named after
# the dir, e.g. test/go/gin_gorm/gin_gorm). Samples are scanned as source, never
# built, so allow-list the sources and ignore anything else that lands in them.
/test/go/*/*
!/test/go/*/*.go
!/test/go/*/go.mod
!/test/go/*/go.sum
!/test/go/*/expected.yaml
!/test/go/*/.gitignore

# Cargo build artifacts left in Rust sample dirs by the frontend's cargo build.
/test/rust/*/target/
/test/rust/*/Cargo.lock
